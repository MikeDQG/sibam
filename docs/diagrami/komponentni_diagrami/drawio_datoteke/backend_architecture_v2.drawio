          value="«external system»&lt;br&gt;&lt;b&gt;Supabase Storage&lt;/b&gt;&lt;br&gt;gold bucket: ONNX models">
          <mxGeometry x="635" y="990" width="210" height="65" as="geometry" />
        </mxCell>

        <!-- External: Google Routes API -->
        <mxCell id="gra_api" parent="1" vertex="1"
